# ── Python ───────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# ── Virtual environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Secrets ──────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Playwright browser profile (contains session cookies) ────
bot_profile/
bot_storage_state.json
# ── Runtime output files (keep folder, ignore contents) ──────
output/*.txt
output/*.html
logs/*.log
logs/*.txt
logs/*.db
data/back_test/*.json
!output/.gitkeep
!logs/.gitkeep
historical_data/*
dataset/
!historical_data/.gitkeep

# ── IDEs ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
catboost_info/
